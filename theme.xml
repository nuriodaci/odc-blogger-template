  &lt;/head&gt;&lt;!--<head/>--&gt;
  <body class='dark' expr:data-blog-id='data:blog.blogId' expr:data-blog-description='data:blog.metaDescription' expr:data-blog-search-label='data:blog.searchLabel' expr:data-blog-search-query='data:blog.searchQuery' expr:data-blog-title='data:blog.title' expr:data-blog-url='data:blog.url' expr:data-home-url='data:blog.homepageUrl' expr:data-page-name='data:blog.pageName' expr:data-page-type='data:blog.pageType'>
    <include expiration='7d' path='*.css'/>
    <include expiration='7d' path='*.js'/>
    <include expiration='3d' path='*.gif'/>
    <include expiration='3d' path='*.jpeg'/>
    <include expiration='3d' path='*.jpg'/>
    <include expiration='3d' path='*.png'/>
    <a class='skip-link' href='#main-content'>Icerige gec</a>
    <b:if cond='!data:view.isError'>
      <header class='site-header'>
        <div class='container-shell header-inner'>
          <b:section class='header-brand' id='header-brand' maxwidgets='1' showaddelement='no'>
            <b:widget id='Header1' locked='true' title='Header' type='Header' version='1'>
              <b:widget-settings>
                <b:widget-setting name='displayUrl'/>
                <b:widget-setting name='displayHeight'>0</b:widget-setting>
                <b:widget-setting name='sectionWidth'>320</b:widget-setting>
                <b:widget-setting name='useImage'>false</b:widget-setting>
                <b:widget-setting name='shrinkToFit'>false</b:widget-setting>
                <b:widget-setting name='imagePlacement'>BEHIND</b:widget-setting>
                <b:widget-setting name='displayWidth'>0</b:widget-setting>
              </b:widget-settings>
              <b:includable id='main'>
                <a class='brand-mark' expr:aria-label='data:title + &quot; ana sayfa&quot;' expr:href='data:blog.homepageUrl'>
                  <span class='brand-mark-icon'>•</span>
                  <span class='brand-mark-copy'>
                    <b:include name='title'/>
                    <b:include name='description'/>
                  </span>
                </a>
              </b:includable>
              <b:includable id='title'>
                <strong><data:title/></strong>
              </b:includable>
              <b:includable id='description'>
                <b:if cond='data:description'>
                  <small><data:description/></small>
                </b:if>
              </b:includable>
            </b:widget>
          </b:section>
          <button aria-controls='primary-menu' aria-expanded='false' class='menu-toggle' data-menu-toggle='toggle' type='button'>
            <span></span>
            <span></span>
            <span></span>
            <span class='sr-only'>Menuyu ac</span>
          </button>
          <nav aria-label='Ana menu' class='primary-nav' data-menu-panel='panel' id='primary-menu'>
            <b:section class='header-menu' id='header-menu' maxwidgets='1' showaddelement='yes'>
              <b:widget id='HTML1' locked='false' title='Menu' type='HTML' version='1'>
                <b:widget-settings>
                  <b:widget-setting name='content'>&lt;a href=&quot;/&quot;&gt;Ana sayfa&lt;/a&gt;
&lt;a href=&quot;/p/kategoriler.html&quot;&gt;Kategoriler&lt;/a&gt;</b:widget-setting>
                </b:widget-settings>
                <b:includable id='main'>
                  <div class='widget-content'>
                    <data:content/>
                  </div>
                </b:includable>
              </b:widget>
            </b:section>
          </nav>
        </div>
      </header>
      <main class='page-shell' id='main-content'>
        <div class='container-shell page-grid'>
          <div class='main-column' id='main-wrapper'>
            <b:section class='main' id='main' showaddelement='no'>
              <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' version='1'>
                <b:widget-settings>
                  <b:widget-setting name='showTimestamp'>true</b:widget-setting>
                  <b:widget-setting name='showAuthor'>true</b:widget-setting>
                  <b:widget-setting name='showLabels'>true</b:widget-setting>
                  <b:widget-setting name='showCommentLink'>false</b:widget-setting>
                  <b:widget-setting name='showShareButtons'>false</b:widget-setting>
                  <b:widget-setting name='showBacklinks'>false</b:widget-setting>
                  <b:widget-setting name='showInlineAds'>false</b:widget-setting>
                  <b:widget-setting name='showDateHeader'>false</b:widget-setting>
                </b:widget-settings>
                <b:includable id='main' var='top'>
                  <b:include data='posts' name='breadcrumb'/>
                  <b:if cond='!data:mobile'>
                    <div class='blog-posts hfeed'>
                      <b:include data='top' name='status-message'/>
                      <b:if cond='data:view.isMultipleItems'>
                        <header class='page-intro reveal'>
                          <b:if cond='data:blog.url == data:blog.homepageUrl and !data:blog.searchQuery and !data:blog.searchLabel'>
                            <p class='eyebrow'><data:blog.title/></p>
                          <b:else/>
                            <b:if cond='data:blog.searchLabel'>
                              <p class='eyebrow'>Kategori</p>
                              <h1><data:blog.searchLabel/></h1>
                            <b:else/>
                              <b:if cond='data:blog.searchQuery'>
                                <p class='eyebrow'>Arama</p>
                                <h1>Arama sonuclari</h1>
                              <b:else/>
                                <b:if cond='data:view.isArchive'>
                                  <p class='eyebrow'>Arsiv</p>
                                  <h1><data:blog.pageTitle/></h1>
                                <b:else/>
                                  <p class='eyebrow'>Yayin</p>
                                  <h1><data:blog.pageTitle/></h1>
                                </b:if>
                              </b:if>
                            </b:if>
                          </b:if>
                        </header>
                      </b:if>
                      <div class='post-grid'>
                        <b:loop values='data:posts' var='post'>
                          <div class='post-outer'>
                            <b:include data='post' name='post'/>
                          </div>
                        </b:loop>
                      </div>
                    </div>
                    <b:include name='nextprev'/>
                    <b:include name='feedLinks'/>
                  <b:else/>
                    <b:include data='top' name='mobile-main'/>
                  </b:if>
                </b:includable>

                <b:includable id='status-message' var='top'>
                  <b:if cond='data:navMessage'>
                    <div class='page-surface surface-panel'>
                      <p><data:navMessage/></p>
                    </div>
                  </b:if>
                </b:includable>

                <b:includable id='breadcrumb' var='posts'>
                  <b:if cond='data:blog.pageType == &quot;item&quot;'>
                    <b:loop values='data:posts' var='post'>
                      <div class='breadcrumbs'>
                        <a expr:href='data:blog.homepageUrl'>Ana sayfa</a>
                        <b:if cond='data:post.labels'>
                          <b:loop index='num' values='data:post.labels' var='label'>
                            <b:if cond='data:num == 0'>
                              <svg aria-hidden='true' viewBox='0 0 24 24'>
                                <path d='M9 6l6 6-6 6' fill='none' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.8'></path>
                              </svg>
                              <a expr:href='data:label.url' rel='tag'><data:label.name/></a>
                            </b:if>
                          </b:loop>
                        </b:if>
                        <svg aria-hidden='true' viewBox='0 0 24 24'>
                          <path d='M9 6l6 6-6 6' fill='none' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.8'></path>
                        </svg>
                        <span aria-current='page'><data:post.title/></span>
                      </div>
                    </b:loop>
                  </b:if>
                  <b:if cond='data:blog.pageType == &quot;static_page&quot;'>
                    <b:loop values='data:posts' var='post'>
                      <div class='breadcrumbs'>
                        <a expr:href='data:blog.homepageUrl'>Ana sayfa</a>
                        <svg aria-hidden='true' viewBox='0 0 24 24'>
                          <path d='M9 6l6 6-6 6' fill='none' stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.8'></path>
                        </svg>
                        <span aria-current='page'><data:post.title/></span>
                      </div>
                    </b:loop>
                  </b:if>
                </b:includable>

                <b:includable id='nextprev'>
                  <b:if cond='data:newerPageUrl or data:olderPageUrl'>
                    <b:if cond='data:blog.pageType == &quot;item&quot;'>
                      <nav aria-label='Yazi gezinmesi' class='pagination pagination-post reveal'>
                        <div class='pagination-post-links'>
                          <b:if cond='data:newerPageUrl'>
                            <a class='pagination-post-link is-prev' expr:href='data:newerPageUrl' rel='prev'>
                              <span aria-hidden='true' class='pagination-post-arrow'>←</span>
                              <span class='pagination-post-content'>
                                <span class='pagination-post-kicker'>Onceki post</span>
                                <span class='pagination-post-title'><data:newerPageTitle/></span>
                              </span>
                            </a>
                          </b:if>
                          <b:if cond='data:olderPageUrl'>
                            <a class='pagination-post-link is-next' expr:href='data:olderPageUrl' rel='next'>
                              <span class='pagination-post-content'>
                                <span class='pagination-post-kicker'>Sonraki post</span>
                                <span class='pagination-post-title'><data:olderPageTitle/></span>
                              </span>
                              <span aria-hidden='true' class='pagination-post-arrow'>→</span>
                            </a>
                          </b:if>
                        </div>
                      </nav>
                    <b:else/>
                      <nav aria-label='Sayfalama' class='pagination surface-panel reveal'>
                        <span class='pagination-label'>Sayfalar</span>
                        <div class='pagination-links'>
                          <b:if cond='data:newerPageUrl'>
                            <a aria-label='Yeni sayfa' class='pagination-link' expr:href='data:newerPageUrl' rel='prev'>&#8249;</a>
                          </b:if>
                          <a class='pagination-link' expr:href='data:blog.homepageUrl'>•</a>
                          <b:if cond='data:olderPageUrl'>
                            <a aria-label='Eski sayfa' class='pagination-link' expr:href='data:olderPageUrl' rel='next'>&#8250;</a>
                          </b:if>
                        </div>
                      </nav>
                    </b:if>
                  </b:if>
                </b:includable>

                <b:includable id='feedLinks'>
                  <b:if cond='data:view.isMultipleItems'>
                    <b:if cond='data:feedLinks'>
                      <div class='sr-only'>
                        <b:include data='feedLinks' name='feedLinksBody'/>
                      </div>
                    </b:if>
                  <b:else/>
                    <div class='sr-only'>
                      <b:loop values='data:posts' var='post'>
                        <b:include cond='data:post.feedLinks' data='post.feedLinks' name='feedLinksBody'/>
                      </b:loop>
                    </div>
                  </b:if>
                </b:includable>

                <b:includable id='feedLinksBody' var='links'>
                  <b:loop values='data:links' var='f'>
                    <a expr:href='data:f.url'><data:f.name/></a>
                  </b:loop>
                </b:includable>

                <b:includable id='tag-row' var='post'>
                  <b:if cond='data:post.labels'>
                    <div class='tag-row'>
                      <b:loop values='data:post.labels' var='label'>
                        <a class='tag-chip' expr:href='data:label.url' rel='tag'><data:label.name/></a>
                      </b:loop>
                    </div>
                  </b:if>
                </b:includable>

                <b:includable id='post-meta' var='post'>
                  <div class='post-meta'>
                    <time expr:datetime='data:post.timestampISO8601'><data:post.timestamp/></time>
                    <b:if cond='data:blog.pageType == &quot;item&quot;'>
                      <span class='dot'></span>
                      <span><data:post.author/></span>
                    </b:if>
                  </div>
                </b:includable>

                <b:includable id='post' var='post'>
                  <b:if cond='data:blog.pageType == &quot;static_page&quot;'>
                    <article class='article-shell surface-panel reveal'>
                      <header class='article-title-block'>
                        <div class='article-title-inner'>
                          <h1><data:post.title/></h1>
                        </div>
                      </header>
                      <div class='article-prose'>
                        <data:post.body/>
                      </div>
                    </article>
                  <b:else/>
                    <b:if cond='data:blog.pageType == &quot;item&quot;'>
                      <article class='article-shell surface-panel reveal' itemscope='itemscope' itemtype='https://schema.org/BlogPosting'>
                        <meta expr:content='data:post.url' itemprop='url'/>
                        <meta expr:content='data:post.timestampISO8601' itemprop='datePublished'/>
                        <meta expr:content='data:post.timestampISO8601' itemprop='dateModified'/>
                        <b:if cond='data:post.snippet'>
                          <meta expr:content='data:post.snippet' itemprop='description'/>
                        </b:if>
                        <div itemprop='mainEntityOfPage' itemscope='itemscope' itemtype='https://schema.org/WebPage'>
                          <meta expr:content='data:post.url' itemprop='url'/>
                        </div>
                        <div itemprop='author' itemscope='itemscope' itemtype='https://schema.org/Person'>
                          <meta expr:content='data:post.author' itemprop='name'/>
                        </div>
                        <div itemprop='publisher' itemscope='itemscope' itemtype='https://schema.org/Organization'>
                          <meta expr:content='data:blog.title' itemprop='name'/>
                        </div>
                        <b:if cond='data:post.firstImageUrl'>
                          <div itemprop='image' itemscope='itemscope' itemtype='https://schema.org/ImageObject'>
                            <meta expr:content='data:post.firstImageUrl' itemprop='url'/>
                            <meta content='1200' itemprop='width'/>
                            <meta content='675' itemprop='height'/>
                          </div>
                        </b:if>
                        <header class='article-title-block'>
                          <div class='article-title-inner'>
                            <b:include data='post' name='tag-row'/>
                            <h1 itemprop='headline'><data:post.title/></h1>
                            <b:include data='post' name='post-meta'/>
                          </div>
                        </header>
                        <b:if cond='data:post.firstImageUrl'>
                          <div class='article-hero'>
                            <img data-featured-image='true' expr:alt='data:post.title' expr:src='resizeImage(data:post.firstImageUrl, 1200, &quot;16:9&quot;)' fetchpriority='high' height='675' itemprop='image' width='1200'/>
                          </div>
                        </b:if>
                        <div class='article-prose' itemprop='articleBody'>
                          <data:post.body/>
                        </div>
                      </article>
                    <b:else/>
                      <article class='post-card surface-panel reveal'>
                        <b:if cond='data:post.firstImageUrl'>
                          <a class='post-card-image-link' expr:aria-label='data:post.title' expr:href='data:post.url'>
                            <img class='post-card-image' expr:alt='data:post.title' expr:src='resizeImage(data:post.firstImageUrl, 960, &quot;16:10&quot;)' height='600' loading='lazy' width='960'/>
                          </a>
                        </b:if>
                        <div class='post-card-body'>
                          <b:include data='post' name='tag-row'/>
                          <b:include data='post' name='post-meta'/>
                          <h2 class='post-card-title'>
                            <b:if cond='data:post.link'>
                              <a expr:href='data:post.link'><data:post.title/></a>
                            <b:else/>
                              <a expr:href='data:post.url'><data:post.title/></a>
                            </b:if>
                          </h2>
                          <p class='post-card-copy'><data:post.snippet/></p>
                        </div>
                      </article>
                    </b:if>
                  </b:if>
                </b:includable>

                <b:includable id='mobile-main' var='top'>
                  <div class='blog-posts hfeed'>
                    <b:include data='top' name='status-message'/>
                    <b:if cond='data:view.isMultipleItems'>
                      <b:loop values='data:posts' var='post'>
                        <div class='post-outer'>
                          <b:include data='post' name='mobile-index-post'/>
                        </div>
                      </b:loop>
                    <b:else/>
                      <b:loop values='data:posts' var='post'>
                        <div class='post-outer'>
                          <b:include data='post' name='mobile-post'/>
                        </div>
                      </b:loop>
                    </b:if>
                  </div>
                  <b:include name='nextprev'/>
                </b:includable>

                <b:includable id='mobile-index-post' var='post'>
                  <b:include data='post' name='post'/>
                </b:includable>

                <b:includable id='mobile-post' var='post'>
                  <b:include data='post' name='post'/>
                </b:includable>
              </b:widget>
            </b:section>
          </div>
          <aside aria-label='Yan panel' class='sidebar' id='sidebar-wrapper'>
            <div class='sidebar-stack'>
              <section class='sidebar-card surface-panel reveal'>
                <div class='sidebar-heading'>
                  <h2>Ara</h2>
                </div>
                <form class='search-shell' expr:action='data:blog.homepageUrl + &quot;search&quot;' method='get' role='search'>
                  <button aria-label='Ara' class='search-submit' type='submit'>
                    <svg aria-hidden='true' class='icon' viewBox='0 0 24 24'>
                      <path d='M10.5 4a6.5 6.5 0 1 0 4.12 11.53l4.42 4.42 1.41-1.41-4.42-4.42A6.5 6.5 0 0 0 10.5 4Z' fill='currentColor'></path>
                    </svg>
                  </button>
                  <input autocomplete='off' id='site-search' name='q' placeholder='Orn. performans' type='search'/>
                </form>
              </section>
              <b:section class='sidebar' id='sidebar' preferred='yes'>
                <b:widget id='PopularPosts1' locked='false' title='Populer yazilar' type='PopularPosts' version='1'>
                  <b:widget-settings>
                    <b:widget-setting name='numItemsToShow'>5</b:widget-setting>
                    <b:widget-setting name='showThumbnails'>false</b:widget-setting>
                    <b:widget-setting name='showSnippets'>false</b:widget-setting>
                    <b:widget-setting name='timeRange'>LAST_WEEK</b:widget-setting>
                  </b:widget-settings>
                  <b:includable id='main'>
                    <section class='sidebar-card surface-panel reveal'>
                      <b:if cond='data:title'>
                        <div class='sidebar-heading'>
                          <h2><data:title/></h2>
                        </div>
                      </b:if>
                      <ul class='sidebar-post-list'>
                        <b:loop values='data:posts' var='post'>
                          <li>
                            <a expr:href='data:post.href'>
                              <span><data:post.title/></span>
                            </a>
                          </li>
                        </b:loop>
                      </ul>
                    </section>
                  </b:includable>
                </b:widget>
                <b:widget id='Label1' locked='false' title='Kategoriler' type='Label' version='1'>
                  <b:widget-settings>
                    <b:widget-setting name='sorting'>ALPHA</b:widget-setting>
                    <b:widget-setting name='display'>LIST</b:widget-setting>
                    <b:widget-setting name='selectedLabelsList'/>
                    <b:widget-setting name='showType'>ALL</b:widget-setting>
                    <b:widget-setting name='showFreqNumbers'>true</b:widget-setting>
                  </b:widget-settings>
                  <b:includable id='main'>
                    <section class='sidebar-card surface-panel reveal'>
                      <b:if cond='data:title'>
                        <div class='sidebar-heading'>
                          <h2><data:title/></h2>
                        </div>
                      </b:if>
                      <ul class='category-list'>
                        <b:loop values='data:labels' var='label'>
                          <li>
                            <b:if cond='data:blog.url == data:label.url'>
                              <a class='is-current' expr:href='data:label.url'>
                                <span><data:label.name/></span>
                                <strong><data:label.count/></strong>
                              </a>
                            <b:else/>
                              <a expr:href='data:label.url'>
                                <span><data:label.name/></span>
                                <strong><data:label.count/></strong>
                              </a>
                            </b:if>
                          </li>
                        </b:loop>
                      </ul>
                    </section>
                  </b:includable>
                </b:widget>
              </b:section>
            </div>
          </aside>
        </div>
      </main>
      <footer class='site-footer'>
        <div class='container-shell footer-grid'>
          <b:section class='footer-brand' id='footer-brand' maxwidgets='1' showaddelement='yes'>
            <b:widget id='HTML2' locked='false' title='Northstar Journal' type='HTML' version='1'>
              <b:widget-settings>
                <b:widget-setting name='content'>&lt;p&gt;Performans, okunabilirlik ve SEO odakli yayin tasarimi notlari.&lt;/p&gt;
&lt;p class=&quot;footer-copy&quot;&gt;Bu alani Layout ekranindan duzenleyebilirsin.&lt;/p&gt;</b:widget-setting>
              </b:widget-settings>
              <b:includable id='main'>
                <section class='footer-block'>
                  <div class='brand-mark brand-mark-footer'>
                    <span class='brand-mark-icon'>•</span>
                    <span class='brand-mark-copy'>
                      <strong><data:title/></strong>
                    </span>
                  </div>
                  <div class='footer-widget-body'>
                    <data:content/>
                  </div>
                </section>
              </b:includable>
            </b:widget>
          </b:section>
          <b:section class='footer-links-section' id='footer-links-section' maxwidgets='1' showaddelement='yes'>
            <b:widget id='HTML3' locked='false' title='Baglantilar' type='HTML' version='1'>
              <b:widget-settings>
                <b:widget-setting name='content'>&lt;ul class=&quot;footer-links&quot;&gt;
&lt;li&gt;&lt;a href=&quot;/&quot;&gt;Ana sayfa&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&quot;/search&quot;&gt;Arama&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&quot;/p/kategoriler.html&quot;&gt;Kategoriler&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;</b:widget-setting>
              </b:widget-settings>
              <b:includable id='main'>
                <section class='footer-block'>
                  <b:if cond='data:title'>
                    <h2><data:title/></h2>
                  </b:if>
                  <div class='footer-widget-body'>
                    <data:content/>
                  </div>
                </section>
              </b:includable>
            </b:widget>
          </b:section>
          <b:section class='footer-contact' id='footer-contact' maxwidgets='1' showaddelement='yes'>
            <b:widget id='HTML4' locked='false' title='Iletisim' type='HTML' version='1'>
              <b:widget-settings>
                <b:widget-setting name='content'>&lt;ul class=&quot;footer-links&quot;&gt;
&lt;li&gt;&lt;a href=&quot;mailto:hello@example.com&quot;&gt;hello@example.com&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a href=&quot;tel:+900000000000&quot;&gt;+90 000 000 00 00&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;span&gt;Istanbul, Turkiye&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;</b:widget-setting>
              </b:widget-settings>
              <b:includable id='main'>
                <section class='footer-block'>
                  <b:if cond='data:title'>
                    <h2><data:title/></h2>
                  </b:if>
                  <div class='footer-widget-body'>
                    <data:content/>
                  </div>
                </section>
              </b:includable>
            </b:widget>
          </b:section>
        </div>
      </footer>
    <b:else/>
      <main class='container-shell error-shell'>
        <div class='page-surface surface-panel'>
          <p class='eyebrow'>404</p>
          <h1>Sayfa bulunamadi</h1>
          <p>Istegin mevcut tema akisi icinde karsilik bulamadi. Ana sayfaya donup yayina devam edebilirsin.</p>
          <div class='error-actions'>
            <a class='button-link' expr:href='data:blog.homepageUrl'>Ana sayfaya don</a>
          </div>
        </div>
      </main>
    </b:if>
        <script defer='defer' src='https://cdn.jsdelivr.net/gh/nuriodaci/odc-blogger-template@main/main.js'></script>
  &lt;!--</body>--&gt; &lt;/body&gt;
</HTML>
