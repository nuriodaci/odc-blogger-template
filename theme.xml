<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<HTML class='dark' expr:dir='data:blog.languageDirection' expr:lang='data:blog.locale'>
  &lt;head&gt;
    <meta charset='utf-8'/>
    <meta content='width=device-width, initial-scale=1, viewport-fit=cover' name='viewport'/>
    <meta content='blogger' name='generator'/>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type'/>
    <link href='https://www.blogger.com/openid-server.g' rel='openid.server'/>
    <link expr:href='data:blog.homepageUrl' rel='openid.delegate'/>
    <link expr:href='data:blog.canonicalUrl' rel='canonical'/>
    <link expr:href='data:blog.homepageUrl + &quot;feeds/posts/default&quot;' expr:title='data:blog.title + &quot; - Atom&quot;' rel='alternate' type='application/atom+xml'/>
    <link expr:href='data:blog.homepageUrl + &quot;feeds/posts/default?alt=rss&quot;' expr:title='data:blog.title + &quot; - RSS&quot;' rel='alternate' type='application/rss+xml'/>
    <b:if cond='data:view.isMultipleItems'>
      <title><data:blog.pageTitle/></title>
    <b:else/>
      <b:if cond='!data:view.isError'>
        <title><data:blog.pageName/> | <data:blog.title/></title>
      </b:if>
    </b:if>
    <b:if cond='data:view.isError'>
      <title>Sayfa Bulunamadi | <data:blog.title/></title>
    </b:if>
    <meta content='#121216' name='theme-color'/>
    <meta content='dark' name='color-scheme'/>
    <meta expr:content='data:blog.localeUnderscoreDelimited' property='og:locale'/>
    <meta expr:content='data:blog.metaDescription' name='description'/>
    <b:if cond='data:blog.searchQuery or data:view.isError'>
      <meta content='noindex,noarchive' name='robots'/>
    <b:else/>
      <meta content='index,follow,max-image-preview:large' name='robots'/>
    </b:if>
    <meta expr:content='data:blog.title' property='og:site_name'/>
    <b:if cond='data:view.isPost or data:view.isPage'>
      <meta expr:content='data:blog.pageName' property='og:title'/>
    <b:else/>
      <meta expr:content='data:blog.pageTitle' property='og:title'/>
    </b:if>
    <meta expr:content='data:blog.canonicalUrl' property='og:url'/>
    <meta expr:content='data:blog.metaDescription' property='og:description'/>
    <b:if cond='data:view.isPost'>
      <meta content='article' property='og:type'/>
    <b:else/>
      <meta content='website' property='og:type'/>
    </b:if>
    <b:if cond='data:blog.postImageUrl'>
      <meta expr:content='data:blog.postImageUrl' property='og:image'/>
      <meta expr:content='data:blog.pageTitle' property='og:image:alt'/>
      <meta expr:content='data:blog.postImageUrl' name='twitter:image'/>
      <meta expr:content='data:blog.pageTitle' name='twitter:image:alt'/>
    </b:if>
    <meta content='summary_large_image' name='twitter:card'/>
    <b:if cond='data:view.isPost or data:view.isPage'>
      <meta expr:content='data:blog.pageName' name='twitter:title'/>
      <meta expr:content='data:blog.metaDescription' name='twitter:description'/>
    <b:else/>
      <meta expr:content='data:blog.pageTitle' name='twitter:title'/>
      <meta expr:content='data:blog.metaDescription' name='twitter:description'/>
    </b:if>
    <b:if cond='data:view.isPost'>
      <script type='application/ld+json'>
        {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          "headline": "<data:blog.pageName/>",
          "url": "<data:blog.url/>",
          "mainEntityOfPage": "<data:blog.url/>",
          "description": "<data:blog.metaDescription/>"<b:if cond='data:blog.postImageUrl'>,
          "image": "<data:blog.postImageUrl/>"</b:if>,
          "publisher": {
            "@type": "Organization",
            "name": "<data:blog.title/>"
          }
        }
      </script>
    <b:else/>
      <b:if cond='data:view.isPage'>
        <script type='application/ld+json'>
          {
            "@context": "https://schema.org",
            "@type": "WebPage",
            "name": "<data:blog.pageName/>",
            "url": "<data:blog.url/>",
            "description": "<data:blog.metaDescription/>"
          }
        </script>
      <b:else/>
      <script type='application/ld+json'>
        {
          "@context": "https://schema.org",
          "@type": "Organization",
          "name": "<data:blog.title/>",
          "url": "<data:blog.homepageUrl/>",
          "description": "<data:blog.metaDescription/>"
        }
      </script>
      <script type='application/ld+json'>
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          "name": "<data:blog.title/>",
          "url": "<data:blog.homepageUrl/>",
          "description": "<data:blog.metaDescription/>",
          "potentialAction": {
            "@type": "SearchAction",
            "target": "<data:blog.homepageUrl/>search?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      </script>
      </b:if>
    </b:if>
        <style>
      :root{color-scheme:dark;--muted-foreground:#9ca3b7}
      *,:before,:after{box-sizing:border-box}
      html{-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;scroll-behavior:smooth;font-family:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}
      body{margin:0;min-height:100vh;background-color:#121216;color:#f6f7fb;overflow-x:clip}
      img{display:block;max-width:100%;height:auto}
      a{color:inherit;text-decoration:none}
      button,input,textarea,select{font:inherit;color:inherit}
      button{cursor:pointer}
      ul,ol{margin:0;padding:0;list-style:none}
      h1,h2,h3,h4,h5,h6,p,figure,blockquote{margin:0}
      .sr-only{clip:rect(0,0,0,0);white-space:nowrap;border:0;width:1px;height:1px;margin:-1px;padding:0;position:absolute;overflow:hidden}
      .skip-link{z-index:60;color:#fff;background:#121216f5;border:1px solid #ffffff29;border-radius:999px;padding:.65rem 1rem;position:fixed;top:1rem;left:1rem;transform:translateY(-150%)}
      .skip-link:focus{transform:translateY(0)}
      .container-shell{width:min(100% - 2rem,78rem);max-width:78rem;margin-inline:auto}
      .surface-panel{background:#111216e0;border:1px solid #ffffff14}
      .site-header{z-index:40;background:#0e0f14bd;border-bottom:1px solid #ffffff0f;position:sticky;top:0;transition:transform .32s cubic-bezier(.4,0,.2,1),opacity .24s ease,background-color .2s ease,box-shadow .2s ease;will-change:transform}
      .site-header.is-scrolled{background:#0e0f14d9;box-shadow:0 10px 30px #00000026}
      .site-header.is-hidden{transform:translateY(calc(-100% - .75rem));opacity:.98}
      .site-header.is-pinned{transform:translateY(0)}
      .header-inner{position:relative;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem;padding-block:.95rem;display:flex}
      .brand-mark{align-items:center;gap:.85rem;display:inline-flex}
      .brand-mark-icon{color:#fff;background:#ffffff14;border-radius:.9rem;place-items:center;width:2.55rem;height:2.55rem;font-weight:700;display:grid}
      .brand-mark-copy{gap:.125rem;display:grid}
      .brand-mark-copy strong{letter-spacing:-.02em;font-size:.95rem}
      .brand-mark-copy small{color:var(--muted-foreground)}
      .menu-toggle{background:#ffffff05;border:1px solid #ffffff1a;border-radius:999px;flex-direction:column;justify-content:center;gap:.28rem;width:2.9rem;height:2.9rem;margin-left:auto;display:inline-flex}
      .menu-toggle span:not(.sr-only){background:#fff;border-radius:999px;width:1rem;height:1.5px;margin-inline:auto;transition:transform .18s,opacity .18s}
      .menu-toggle[aria-expanded=true] span:first-child{transform:translateY(.36rem) rotate(45deg)}
      .menu-toggle[aria-expanded=true] span:nth-child(2){opacity:0}
      .menu-toggle[aria-expanded=true] span:nth-child(3){transform:translateY(-.36rem) rotate(-45deg)}
      .primary-nav{box-sizing:border-box;flex-direction:column;order:3;gap:.5rem;width:100%;padding-top:1rem;display:none;background:#111216f2;border:1px solid #ffffff14;border-radius:1.1rem;padding:.5rem;box-shadow:0 18px 48px #00000045}
      .primary-nav.is-open{display:flex}
      .primary-nav .widget-content{display:contents}
      .primary-nav a{color:#fffc;border-radius:999px;align-items:center;width:100%;min-height:3rem;padding:.9rem 1rem;display:flex}
      .page-shell{padding-block:1.4rem 3.5rem}
      .page-grid{display:grid;gap:1.25rem}
      .main-column,.section-block,.post-grid,.post-card,.post-card-body,.featured-showcase-layout,.featured-mini-grid,.featured-lead,.featured-mini,.sidebar-card,.tab-panels,.search-results,.sidebar-post-list,.category-list,.post-outer{min-width:0}
      .main.section,.sidebar.section,.main.section>.widget,.sidebar.section>.widget,.header-brand.section,.header-menu.section,.footer-brand.section,.footer-links-section.section,.footer-contact.section,.header-brand.section>.widget,.header-menu.section>.widget,.footer-brand.section>.widget,.footer-links-section.section>.widget,.footer-contact.section>.widget{margin:0;display:contents}
      .blog-posts{display:grid;gap:1.25rem}
      .page-intro{gap:.7rem;padding:.2rem 0 .35rem;display:grid}
      .eyebrow{color:var(--muted-foreground);letter-spacing:.18em;text-transform:uppercase;margin:0 0 .5rem;font-size:.76rem;font-weight:600}
      .post-grid{grid-template-columns:1fr;gap:1rem;display:grid}
      .post-card,.sidebar-card,.article-shell,.pagination,.about-story,.about-principle,.about-process,.contact-primary,.contact-detail,.contact-note{border-radius:1.5rem}
      .post-card{background:#111216e0;border:1px solid #ffffff14;overflow:clip}
      .post-card-image-link{display:block}
      .post-card-image{aspect-ratio:16/10;object-fit:cover;width:100%}
      .post-card-body{gap:.85rem;padding:1rem;display:grid}
      .post-card-title{letter-spacing:-.04em;overflow-wrap:anywhere;word-break:break-word;font-size:clamp(1.2rem,3vw,1.55rem);line-height:1.05}
      .post-card-copy{color:#ffffffbd;overflow-wrap:anywhere;line-height:1.7}
      .post-meta{color:var(--muted-foreground);flex-wrap:wrap;align-items:center;gap:.45rem;font-size:.82rem;display:flex}
      .tag-row{flex-wrap:wrap;gap:.55rem;display:flex}
      .tag-chip{color:#ffffffc7;border:1px solid #ffffff1a;border-radius:999px;align-items:center;min-height:2rem;padding-inline:.8rem;font-size:.8rem;display:inline-flex}
      .sidebar-stack{gap:1.1rem;display:grid}
      .sidebar-card{background:#121318eb;padding:1rem}
      .sidebar-heading{border-bottom:1px solid #ffffff0f;gap:.35rem;margin-bottom:.85rem;padding-bottom:.75rem;display:grid}
      .search-shell{background:#ffffff06;border:1px solid #ffffff14;border-radius:1.1rem;align-items:center;gap:.75rem;min-height:3.35rem;padding:.35rem .9rem;display:flex}
      .search-shell input{color:#fff;background:transparent;border:0;width:100%;min-width:0;padding-block:.55rem}
      .search-submit{display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;padding:0;border:0;background:transparent}
      .icon{width:1rem;height:1rem;color:var(--muted-foreground);flex-shrink:0}
      .sidebar-post-list,.category-list,.footer-links,.search-results{gap:.55rem;display:grid}
      .sidebar-post-list a,.category-list a,.search-results a{background:#ffffff06;border:1px solid #ffffff0d;border-radius:1rem;justify-content:space-between;align-items:flex-start;gap:.75rem;padding:.8rem .9rem;display:flex}
      .sidebar-post-list span,.category-list span,.search-results span{overflow-wrap:anywhere;color:#ffffffe6;min-width:0;line-height:1.45}
      .sidebar-post-list small,.category-list strong,.search-results small{color:var(--muted-foreground);white-space:nowrap;flex-shrink:0;padding-top:.1rem}
      .article-shell{background:#111216e0;border:1px solid #ffffff14;overflow:clip}
      .article-title-block{text-align:center;padding:1.4rem 1rem 1.15rem}
      .article-title-inner{gap:.95rem;max-width:52rem;margin-inline:auto;display:grid}
      .article-title-block .tag-row,.article-title-block .post-meta{justify-content:center}
      .article-title-block h1{letter-spacing:-.045em;font-size:clamp(1.8rem,4.2vw,2.95rem);line-height:1.02}
      .article-hero img{aspect-ratio:16/9;object-fit:cover;width:100%}
      .article-prose{padding-inline:1rem;padding-top:1rem;padding-bottom:1.25rem}
      .article-prose p,.article-prose li,.article-prose blockquote{font-size:1rem;line-height:1.85}
      .article-prose img{height:auto;max-width:100%}
      .pagination-post{background:transparent;border:0;padding:0}
      .pagination-post-links{grid-template-columns:1fr;gap:.9rem;display:grid}
      .pagination-post-link{background:#101117f2;border:1px solid #ffffff14;border-radius:1.35rem;grid-template-columns:auto minmax(0,1fr);align-items:center;gap:1rem;min-height:6.5rem;padding:1rem 1.1rem;display:grid}
      .pagination-post-link.is-next{grid-template-columns:minmax(0,1fr) auto;text-align:right}
      .pagination-post-arrow{color:#fff;background:#ffffff08;border:1px solid #ffffff12;border-radius:999px;place-items:center;width:2.9rem;height:2.9rem;font-size:1.05rem;display:grid}
      .pagination-post-content{gap:.3rem;min-width:0;display:grid}
      .pagination-post-kicker{color:var(--muted-foreground);letter-spacing:.12em;text-transform:uppercase;font-size:.68rem;font-weight:700}
      .pagination-post-title{color:#fff;overflow-wrap:anywhere;font-size:1rem;font-weight:600;line-height:1.4}
      .pagination-post-link.is-next .pagination-post-content{justify-items:end}
      .site-footer{background:#0c0d11b8;border-top:1px solid #ffffff14}
      .footer-grid{gap:1.35rem;padding-block:2rem;display:grid}
      .footer-widget-body{color:#ffffffbd;gap:.8rem;display:grid}
      .footer-widget-body p,.footer-widget-body li,.footer-widget-body a,.footer-widget-body span{color:#ffffffbd;line-height:1.7}
      .button-link{background:#ffffff08;border:1px solid #ffffff1a;border-radius:999px;align-items:center;justify-content:center;min-height:2.9rem;padding:0 1.1rem;display:inline-flex}
      .error-shell{padding-block:4rem}
      body[data-page-type='item'] .post-grid,body[data-page-type='static_page'] .post-grid{grid-template-columns:1fr}
      body[data-page-type='item'] .article-shell,body[data-page-type='static_page'] .article-shell{width:100%}
      @media (max-width:1023px){.site-header{backdrop-filter:blur(14px)}.primary-nav{position:absolute;top:calc(100% + .75rem);right:0;left:0;margin:0;width:100%;padding:.55rem}.sidebar{margin-top:1.6rem;width:auto;margin-inline:-1rem;padding-inline:1rem}}
      @media (min-width:768px){.footer-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.article-prose{padding-inline:1.4rem}.page-intro{padding-top:.35rem}.article-title-block{padding-inline:1.4rem;padding-top:1.65rem;padding-bottom:1.3rem}.pagination-post-links{grid-template-columns:repeat(2,minmax(0,1fr))}}
      @media (min-width:1024px){.header-inner{flex-wrap:nowrap;align-items:center}.menu-toggle{display:none}.primary-nav{flex-direction:row;justify-content:flex-end;align-items:center;gap:.35rem;width:auto;margin-left:auto;padding-top:0;display:flex;background:transparent;border:0;box-shadow:none;padding:0}.primary-nav a{white-space:nowrap;width:auto;min-height:2.7rem;padding:.7rem 1rem;display:inline-flex}.page-shell{padding-block:2rem 4.5rem}.page-grid{grid-template-columns:minmax(0,1fr) 21rem;align-items:start}.sidebar{margin-top:1rem;position:sticky;top:7rem}.post-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.footer-grid{grid-template-columns:1.2fr 1fr 1fr}}
      @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto}*,:before,:after{scroll-behavior:auto!important;transition-duration:.01ms!important;animation-duration:.01ms!important;animation-iteration-count:1!important}.site-header{transition:none}}
    </style>

